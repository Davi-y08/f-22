{
  "agent_id": "stealth-lens-knife-lite",
  "device": "cpu",
  "status_interval_seconds": 15,
  "logging": {
    "level": "INFO",
    "json": true
  },
  "storage": {
    "events_dir": "artifacts/events",
    "snapshots_dir": "artifacts/snapshots",
    "status_path": "artifacts/status/agent-status.json"
  },
  "model_catalog": {
    "knife_monitor": {
      "path": "models/knife_monitor.onnx",
      "backend": "onnx",
      "class_names": [
        "person",
        "knife"
      ],
      "class_filters": [
        "knife"
      ],
      "event_type": "knife_detected",
      "confidence": 0.60,
      "iou": 0.45,
      "cooldown_seconds": 4,
      "emit_events": true,
      "use_tracking": true,
      "enabled": true
    }
  },
  "cameras": [
    {
      "id": "camera-entrada",
      "name": "Entrada",
      "source": 0,
      "models": [
        "knife_monitor"
      ],
      "fps_analysis": 3,
      "enabled": true,
      "snapshot_on_event": true,
      "queue_maxsize": 4,
      "cooldown_seconds": 4,
      "backend_preference": "auto",
      "zones": [],
      "display": {
        "enabled": true,
        "window_name": "Stealth Lens Knife Agent - Entrada",
        "show_metrics": true,
        "draw_zones": true,
        "max_width": null,
        "target_fps": 30,
        "fullscreen": false,
        "fit_mode": "contain",
        "interpolation": "auto",
        "enhance": true
      },
      "smoking_behavior": {
        "enabled": false
      }
    }
  ]
}
